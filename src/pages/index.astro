---
import Layout from "../layouts/Layout.astro";
import GlitchText from "../components/GlitchText";
---

<Layout
  title="RANDOM TANTRUM"
  description="Random Tantrum builds HTTP and LLM systems for small businesses."
>
  <main class="rt-text main-container">
    <h1 class="rt-heading heading-lg">
      <GlitchText text="RANDOM" client:load /><br /><GlitchText
        text="TANTRUM"
        client:load
      />
    </h1>

    <section class="property-section" aria-labelledby="properties-heading">
      <h2 id="properties-heading" class="property-heading">
        HTTP and LLM success<br />for small businesses.
      </h2>
    </section>

    <div class="grid property-grid">
      <a
        href="https://www.collxn.com/"
        class="box property-card"
        target="_blank"
        rel="noopener"
      >
        <span class="property-title">Collxn</span>
        <span class="property-description"
          >daily vinyl collection rediscovery</span
        >
      </a>
      <a
        href="https://www.hanayou.studio/"
        class="box property-card"
        target="_blank"
        rel="noopener"
      >
        <span class="property-title">HanaYou</span>
        <span class="property-description"
          >Kyoto ikebana classes and guides</span
        >
      </a>
      <a
        href="https://www.ashryan.io/"
        class="box property-card"
        target="_blank"
        rel="noopener"
      >
        <span class="property-title">ashryan.io</span>
        <span class="property-description">product leadership and writing</span>
      </a>
    </div>
  </main>

  <footer class="rt-text site-footer">
    <div id="copyright"></div>
  </footer>
</Layout>

<script>
  const updateCopyright = () => {
    const currentYear = new Date().getFullYear();
    const element = document.getElementById("copyright");

    if (!element) return;

    if (currentYear <= 2025) {
      element.textContent = "(c) 2025 Random Tantrum, LLC";
    } else {
      element.textContent = `(c) 2025–${currentYear} Random Tantrum, LLC`;
    }
  };

  // Run on page load
  updateCopyright();

  // Also update on New Year if page is kept open
  setInterval(
    () => {
      updateCopyright();
    },
    1000 * 60 * 60,
  ); // Check every hour
</script>
